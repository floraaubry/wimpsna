<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <AssemblyName>WhereIsMyPSNA</AssemblyName>
    <RootNamespace>WhereIsMyPSNA</RootNamespace>
    <PlatformTarget>x64</PlatformTarget>
    <LangVersion>latest</LangVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="BlishHUD" Version="1.2.0" PrivateAssets="all" ExcludeAssets="runtime" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="System.ComponentModel.Composition" />
    <Reference Include="System.Windows.Forms" />
    <Reference Include="System.Net.Http" />
  </ItemGroup>

  <Target Name="PackBhm" AfterTargets="Build">
    <ItemGroup>
      <BhmCoreFiles Include="$(OutputPath)WhereIsMyPSNA.dll" />
      <BhmCoreFiles Include="$(OutputPath)WhereIsMyPSNA.pdb" />
      <BhmCoreFiles Include="$(ProjectDir)manifest.json" />
      <BhmRefFiles Include="$(ProjectDir)ref\psna.png" />
      <BhmRefFiles Include="$(ProjectDir)ref\window_bg.png" />
      <BhmRefFiles Include="$(ProjectDir)ref\window_emblem.png" />
    </ItemGroup>
    <Copy SourceFiles="@(BhmCoreFiles)" DestinationFolder="$(OutputPath)bhm_staging\" />
    <Copy SourceFiles="@(BhmRefFiles)" DestinationFolder="$(OutputPath)bhm_staging\ref\" />
    <ZipDirectory
      SourceDirectory="$(OutputPath)bhm_staging\"
      DestinationFile="$(ProjectDir)WhereIsMyPSNA.bhm"
      Overwrite="true" />
  </Target>

</Project>